{
  "openapi": "3.0.3",
  "info": {
    "title": "SEO Audit API",
    "version": "1.0.0",
    "description": "SEO Audit API. Full on-page SEO audit: title, meta description, H1–H6 headings, image alt coverage, internal/external links, Open Graph, schema.org types, canonical URL, robots meta, and a 0–100 SEO score with grade. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by Zyla API Hub."
  },
  "servers": [
    {
      "url": "https://sitetrace-zyla.onrender.com",
      "description": "zyla production base URL"
    }
  ],
  "paths": {
    "/api/seo-audit": {
      "post": {
        "summary": "SEO Audit",
        "description": "Full on-page SEO audit: title, meta description, H1–H6 headings, image alt coverage, internal/external links, Open Graph, schema.org types, canonical URL, robots meta, and a 0–100 SEO score with grade.",
        "operationId": "seoAudit",
        "tags": [
          "SEO"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Public HTTP or HTTPS website URL to analyze.",
                    "example": "https://example.com"
                  },
                  "max_urls": {
                    "type": "integer",
                    "description": "Optional sitemap result limit for /api/sitemap-analyzer.",
                    "minimum": 1,
                    "maximum": 2000,
                    "example": 500
                  }
                }
              },
              "example": {
                "url": "https://example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        }
      }
    }
  }
}
