{
  "openapi": "3.0.3",
  "info": {
    "title": "Contact Enricher API",
    "version": "1.0.0",
    "description": "Contact Enricher API. Enrich contacts with company, job title, and social profile data. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by Zyla API Hub."
  },
  "servers": [
    {
      "url": "https://sitetrace-zyla.onrender.com",
      "description": "zyla production base URL"
    }
  ],
  "paths": {
    "/api/contact-enricher": {
      "post": {
        "summary": "Contact Enricher",
        "description": "Enrich contacts with company, job title, and social profile data.",
        "operationId": "contactEnricher",
        "tags": [
          "Identity & Fraud"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "john@example.com"
                  },
                  "name": {
                    "type": "string",
                    "example": "John Smith"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+12025551234"
                  },
                  "company": {
                    "type": "string",
                    "example": "Acme Corp"
                  }
                }
              },
              "example": {
                "email": "john@example.com",
                "name": "John Smith"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        }
      }
    }
  }
}
