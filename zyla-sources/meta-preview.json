{
  "openapi": "3.0.3",
  "info": {
    "title": "Meta Preview API",
    "version": "1.0.0",
    "description": "Meta Preview API. Extract Open Graph, Twitter Card, LinkedIn, and basic page metadata for social previews. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by Zyla API Hub."
  },
  "servers": [
    {
      "url": "https://sitetrace-zyla.onrender.com",
      "description": "zyla production base URL"
    }
  ],
  "paths": {
    "/api/meta-preview": {
      "post": {
        "summary": "Meta Preview",
        "description": "Extract Open Graph, Twitter Card, LinkedIn, and basic page metadata for social previews.",
        "operationId": "metaPreview",
        "tags": [
          "Social",
          "SEO"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Public HTTP or HTTPS website URL to analyze.",
                    "example": "https://example.com"
                  },
                  "max_urls": {
                    "type": "integer",
                    "description": "Optional sitemap result limit for /api/sitemap-analyzer.",
                    "minimum": 1,
                    "maximum": 2000,
                    "example": 500
                  }
                }
              },
              "example": {
                "url": "https://example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        }
      }
    }
  }
}
