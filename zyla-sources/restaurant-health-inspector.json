{
  "openapi": "3.0.3",
  "info": {
    "title": "Restaurant Health Inspector API",
    "version": "1.0.0",
    "description": "Restaurant Health Inspector API. Access public health inspection records and scores for restaurants by name and location. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by Zyla API Hub."
  },
  "servers": [
    {
      "url": "https://sitetrace-zyla.onrender.com",
      "description": "zyla production base URL"
    }
  ],
  "paths": {
    "/api/restaurant-health-inspector": {
      "post": {
        "summary": "Restaurant Health Inspector",
        "description": "Access public health inspection records and scores for restaurants by name and location.",
        "operationId": "restaurantHealthInspector",
        "tags": [
          "Food & Health"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "restaurant_name": {
                    "type": "string",
                    "example": "McDonalds"
                  },
                  "address": {
                    "type": "string",
                    "example": "123 Main St"
                  },
                  "city": {
                    "type": "string",
                    "example": "New York"
                  },
                  "state": {
                    "type": "string",
                    "example": "NY"
                  },
                  "zip": {
                    "type": "string",
                    "example": "10001"
                  }
                }
              },
              "example": {
                "restaurant_name": "McDonalds",
                "city": "New York",
                "state": "NY"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        }
      }
    }
  }
}
