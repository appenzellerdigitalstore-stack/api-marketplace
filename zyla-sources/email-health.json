{
  "openapi": "3.0.3",
  "info": {
    "title": "Email Health API",
    "version": "1.0.0",
    "description": "Email Health API. Validate email addresses, check breach status, and score deliverability. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by Zyla API Hub."
  },
  "servers": [
    {
      "url": "https://sitetrace-zyla.onrender.com",
      "description": "zyla production base URL"
    }
  ],
  "paths": {
    "/api/email-health": {
      "post": {
        "summary": "Email Health",
        "description": "Validate email addresses, check breach status, and score deliverability.",
        "operationId": "emailHealth",
        "tags": [
          "Identity & Fraud"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "user@example.com"
                  },
                  "emails": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "user@example.com",
                      "test@domain.com"
                    ]
                  }
                }
              },
              "example": {
                "email": "user@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        }
      }
    }
  }
}
