{
  "openapi": "3.0.3",
  "info": {
    "title": "Freight Estimator API",
    "version": "1.0.0",
    "description": "Freight Estimator API. Get instant freight shipping quotes across air, ocean, ground, and express carriers for any origin/destination pair. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by ."
  },
  "servers": [
    {
      "url": "https://sitetrace-rapidapi.onrender.com",
      "description": "rapidapi production base URL"
    }
  ],
  "paths": {
    "/api/freight-estimator": {
      "post": {
        "summary": "Freight Estimator",
        "description": "Get instant freight shipping quotes across air, ocean, ground, and express carriers for any origin/destination pair.",
        "operationId": "freightEstimator",
        "tags": [
          "Supply Chain"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "origin_country",
                  "destination_country",
                  "weight_kg"
                ],
                "properties": {
                  "origin_country": {
                    "type": "string",
                    "example": "US"
                  },
                  "destination_country": {
                    "type": "string",
                    "example": "DE"
                  },
                  "weight_kg": {
                    "type": "number",
                    "example": 50
                  },
                  "dimensions_cm": {
                    "type": "string",
                    "example": "60x40x30"
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "air",
                      "ocean",
                      "ground",
                      "express"
                    ],
                    "example": "air"
                  },
                  "value_usd": {
                    "type": "number",
                    "example": 5000
                  }
                }
              },
              "example": {
                "origin_country": "US",
                "destination_country": "DE",
                "weight_kg": 50,
                "mode": "air"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        },
        "parameters": [
          {
            "name": "X-RapidAPI-Key",
            "in": "header",
            "required": true,
            "description": "RapidAPI application key. RapidAPI injects this for subscribed consumers.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-RapidAPI-Host",
            "in": "header",
            "required": true,
            "description": "RapidAPI host for this API listing.",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
