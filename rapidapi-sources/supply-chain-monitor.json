{
  "openapi": "3.0.3",
  "info": {
    "title": "Supply Chain Monitor API",
    "version": "1.0.0",
    "description": "Supply Chain Monitor API. Live disruption alerts and country risk scores for supply chain monitoring. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by ."
  },
  "servers": [
    {
      "url": "https://sitetrace-rapidapi.onrender.com",
      "description": "rapidapi production base URL"
    }
  ],
  "paths": {
    "/api/supply-chain-monitor": {
      "post": {
        "summary": "Supply Chain Monitor",
        "description": "Live disruption alerts and country risk scores for supply chain monitoring.",
        "operationId": "supplyChainMonitor",
        "tags": [
          "Supply Chain"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "industry": {
                    "type": "string",
                    "example": "electronics"
                  },
                  "countries": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "CN",
                      "TW",
                      "JP"
                    ]
                  },
                  "product_category": {
                    "type": "string",
                    "example": "semiconductors"
                  },
                  "alert_severity": {
                    "type": "string",
                    "example": "high"
                  }
                }
              },
              "example": {
                "industry": "electronics",
                "countries": [
                  "CN",
                  "TW"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        },
        "parameters": [
          {
            "name": "X-RapidAPI-Key",
            "in": "header",
            "required": true,
            "description": "RapidAPI application key. RapidAPI injects this for subscribed consumers.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-RapidAPI-Host",
            "in": "header",
            "required": true,
            "description": "RapidAPI host for this API listing.",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
