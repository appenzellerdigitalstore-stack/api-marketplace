{
  "openapi": "3.0.3",
  "info": {
    "title": "Robots.txt Analyzer API",
    "version": "1.0.0",
    "description": "Robots.txt Analyzer API. Fetch and parse a site's robots.txt file, including user-agent groups, allow/disallow rules, crawl-delay values, sitemap declarations, and insights. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by ."
  },
  "servers": [
    {
      "url": "https://sitetrace-rapidapi.onrender.com",
      "description": "rapidapi production base URL"
    }
  ],
  "paths": {
    "/api/robots-analyzer": {
      "post": {
        "summary": "Robots Analyzer",
        "description": "Fetch and parse a site's robots.txt file, including user-agent groups, allow/disallow rules, crawl-delay values, sitemap declarations, and insights.",
        "operationId": "robotsAnalyzer",
        "tags": [
          "Crawlability"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Public HTTP or HTTPS website URL to analyze.",
                    "example": "https://example.com"
                  },
                  "max_urls": {
                    "type": "integer",
                    "description": "Optional sitemap result limit for /api/sitemap-analyzer.",
                    "minimum": 1,
                    "maximum": 2000,
                    "example": 500
                  }
                }
              },
              "example": {
                "url": "https://example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        },
        "parameters": [
          {
            "name": "X-RapidAPI-Key",
            "in": "header",
            "required": true,
            "description": "RapidAPI application key. RapidAPI injects this for subscribed consumers.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-RapidAPI-Host",
            "in": "header",
            "required": true,
            "description": "RapidAPI host for this API listing.",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
