{
  "openapi": "3.0.3",
  "info": {
    "title": "Supplier Finder API",
    "version": "1.0.0",
    "description": "Supplier Finder API. Discover vetted global suppliers by product category and country. Send a JSON POST request and receive a structured JSON response. Pricing, quotas, authentication, and subscriptions are handled by ."
  },
  "servers": [
    {
      "url": "https://sitetrace-rapidapi.onrender.com",
      "description": "rapidapi production base URL"
    }
  ],
  "paths": {
    "/api/supplier-finder": {
      "post": {
        "summary": "Supplier Finder",
        "description": "Discover vetted global suppliers by product category and country.",
        "operationId": "supplierFinder",
        "tags": [
          "Supply Chain"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "product_category": {
                    "type": "string",
                    "example": "electronics"
                  },
                  "countries": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "CN",
                      "IN",
                      "VN"
                    ]
                  },
                  "certifications": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "ISO9001"
                    ]
                  },
                  "moq_max": {
                    "type": "integer",
                    "example": 1000
                  },
                  "sample_required": {
                    "type": "boolean",
                    "example": true
                  }
                }
              },
              "example": {
                "product_category": "electronics",
                "countries": [
                  "CN"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful JSON response from the API.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                },
                "example": {
                  "success": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing request fields."
          },
          "429": {
            "description": "Rate limit exceeded for the current plan."
          },
          "500": {
            "description": "Unexpected server error."
          }
        },
        "parameters": [
          {
            "name": "X-RapidAPI-Key",
            "in": "header",
            "required": true,
            "description": "RapidAPI application key. RapidAPI injects this for subscribed consumers.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-RapidAPI-Host",
            "in": "header",
            "required": true,
            "description": "RapidAPI host for this API listing.",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
